# ── ResQ environment variables ───────────────────────────────────────────────
# Copy to .env and fill in real values before running docker compose.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=resq
POSTGRES_PASSWORD=resq
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resq_db

# ── FastAPI / Auth ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── Frontend ───────────────────────────────────────────────────────────────────
# Baked into the JS bundle at build time (Vite build arg).
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Twilio SMS (optional — falls back to mock if unset) ──────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── SMTP Email (optional — falls back to mock if unset) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Firebase Cloud Messaging / Push (optional) ────────────────────────────────
FCM_SERVER_KEY=

# ── Admin seed (used by scripts/create_admin.py) ─────────────────────────────
ADMIN_EMAIL=admin@resq.dev
ADMIN_PASSWORD=change-me-before-deploying
ADMIN_FULL_NAME=ResQ Admin
ADMIN_PHONE=+910000000000
